<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PortfolioHub - Digital Portfolio Builder</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="container">
            <div class="logo">PortfolioHub</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#features">Features</a></li>
                <li><a href="#templates">Templates</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div class="nav-buttons">
                <button class="btn-login">Login</button>
                <button class="btn-signup">Sign Up</button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <h1>Create Your Digital Portfolio in Minutes</h1>
                <p>Build stunning, professional portfolios without coding. Showcase your work and impress potential clients.</p>
                <button class="btn-primary">Get Started Free</button>
            </div>
            <div class="hero-image">
                <div class="mockup">
                    <div class="mockup-screen"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features">
        <div class="container">
            <h2>Powerful Features</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">🎨</div>
                    <h3>Beautiful Templates</h3>
                    <p>Choose from 50+ professionally designed templates for any industry.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h3>Easy to Use</h3>
                    <p>Drag and drop editor makes building your portfolio simple and intuitive.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📱</div>
                    <h3>Mobile Responsive</h3>
                    <p>Your portfolio looks perfect on all devices - desktop, tablet, and mobile.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h3>SEO Optimized</h3>
                    <p>Built-in SEO tools help your portfolio rank higher in search results.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔐</div>
                    <h3>Secure & Reliable</h3>
                    <p>SSL encryption and 99.9% uptime guarantee for your peace of mind.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📊</div>
                    <h3>Analytics & Stats</h3>
                    <p>Track visitors, get insights, and measure your portfolio's performance.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Templates Section -->
    <section id="templates" class="templates">
        <div class="container">
            <h2>Choose Your Template</h2>
            <div class="templates-grid">
                <div class="template-card">
                    <div class="template-preview creative"></div>
                    <h3>Creative</h3>
                    <p>Perfect for designers and artists</p>
                    <button class="btn-secondary">Use Template</button>
                </div>
                <div class="template-card">
                    <div class="template-preview minimal"></div>
                    <h3>Minimal</h3>
                    <p>Clean and professional look</p>
                    <button class="btn-secondary">Use Template</button>
                </div>
                <div class="template-card">
                    <div class="template-preview modern"></div>
                    <h3>Modern</h3>
                    <p>Contemporary and sleek design</p>
                    <button class="btn-secondary">Use Template</button>
                </div>
                <div class="template-card">
                    <div class="template-preview corporate"></div>
                    <h3>Corporate</h3>
                    <p>Professional for all industries</p>
                    <button class="btn-secondary">Use Template</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="pricing">
        <div class="container">
            <h2>Simple Pricing</h2>
            <div class="pricing-grid">
                <div class="pricing-card">
                    <h3>Free</h3>
                    <div class="price">$0<span>/month</span></div>
                    <ul class="price-features">
                        <li>✓ 1 Portfolio</li>
                        <li>✓ Basic Templates</li>
                        <li>✓ 1 GB Storage</li>
                        <li>✗ Custom Domain</li>
                        <li>✗ Analytics</li>
                    </ul>
                    <button class="btn-secondary">Get Started</button>
                </div>
                <div class="pricing-card featured">
                    <h3>Pro</h3>
                    <div class="price">$9<span>/month</span></div>
                    <ul class="price-features">
                        <li>✓ 5 Portfolios</li>
                        <li>✓ All Templates</li>
                        <li>✓ 50 GB Storage</li>
                        <li>✓ Custom Domain</li>
                        <li>✓ Advanced Analytics</li>
                    </ul>
                    <button class="btn-primary">Start Free Trial</button>
                </div>
                <div class="pricing-card">
                    <h3>Business</h3>
                    <div class="price">$29<span>/month</span></div>
                    <ul class="price-features">
                        <li>✓ Unlimited Portfolios</li>
                        <li>✓ Premium Templates</li>
                        <li>✓ Unlimited Storage</li>
                        <li>✓ Multiple Domains</li>
                        <li>✓ Priority Support</li>
                    </ul>
                    <button class="btn-secondary">Get Started</button>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <div class="container">
            <h2>Ready to Build Your Portfolio?</h2>
            <p>Join thousands of professionals who've created their digital portfolios with PortfolioHub.</p>
            <button class="btn-primary">Start Your Free Portfolio Today</button>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2>Get in Touch</h2>
            <form class="contact-form">
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
                <textarea placeholder="Your Message" rows="5" required></textarea>
                <button type="submit" class="btn-primary">Send Message</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>PortfolioHub</h4>
                    <p>Create beautiful portfolios in minutes.</p>
                </div>
                <div class="footer-section">
                    <h4>Product</h4>
                    <ul>
                        <li><a href="#">Features</a></li>
                        <li><a href="#">Pricing</a></li>
                        <li><a href="#">Templates</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="#">About</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Legal</h4>
                    <ul>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 PortfolioHub. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
